rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function tournamentDoc(tournamentId) {
      return get(/databases/$(database)/documents/tournaments/$(tournamentId)).data;
    }

    function isTournamentOrganizer(tournamentId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/tournaments/$(tournamentId))
        && (
          tournamentDoc(tournamentId).get('createdBy', '') == request.auth.uid
          || tournamentDoc(tournamentId).get('organizerId', '') == request.auth.uid
        );
    }

    function isTournamentOrganizerOnCreate() {
      return isSignedIn()
        && (
          request.resource.data.get('createdBy', '') == request.auth.uid
          || request.resource.data.get('organizerId', '') == request.auth.uid
        );
    }

    /// Invited official accepting or declining (status-only update).
    function canOfficialInviteeRespond() {
      return isSignedIn()
        && resource.data.get('userId', '') == request.auth.uid
        && resource.data.get('status', 'pending') == 'pending'
        && request.resource.data.status in ['active', 'declined']
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt']);
    }

    function matchData(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data;
    }

    function isMatchCreator(matchId) {
      return isSignedIn() && matchData(matchId).createdBy == request.auth.uid;
    }

    function isUpcomingMatchStatus(status) {
      return status in ['draft', 'scheduled', 'tossCompleted'];
    }

    function canDeleteMatch(matchId) {
      let data = matchData(matchId);
      return isMatchCreator(matchId)
        || (
          isSignedIn()
          && 'tournamentId' in data
          && data.tournamentId is string
          && data.tournamentId.size() > 0
          && isTournamentOrganizer(data.tournamentId)
          && 'status' in data
          && isUpcomingMatchStatus(data.status)
        );
    }

    function effectiveScorerId(matchId) {
      let data = matchData(matchId);
      return ('currentScorerId' in data && data.currentScorerId is string
              && data.currentScorerId.size() > 0)
        ? data.currentScorerId
        : data.createdBy;
    }

    function isActiveScorer(matchId) {
      return isSignedIn() && effectiveScorerId(matchId) == request.auth.uid;
    }

    function isLegacyMatchScorer(matchId) {
      let data = matchData(matchId);
      return !('currentScorerId' in data)
        || data.currentScorerId == null
        || data.currentScorerId == '';
    }

    function isMatchScorer(matchId) {
      let data = matchData(matchId);
      return isSignedIn() && (
        (('scorer1UserId' in data) && data.scorer1UserId == request.auth.uid) ||
        (('scorer2UserId' in data) && data.scorer2UserId == request.auth.uid) ||
        isActiveScorer(matchId) ||
        (isLegacyMatchScorer(matchId) && (
          isMatchCreator(matchId) ||
          request.auth.uid in data.scorerIds
        ))
      );
    }

    // --- Revise target / end innings (aligned with lib/core/utils/match_scorer_utils.dart) ---

    function officialEntryUserId(entry) {
      return entry is map ? entry.get('userId', '') : '';
    }

    /// Scorer 1 / 2 from match officials snapshot (when top-level scorer ids are absent).
    function isAssignedMatchScorer(matchId) {
      let data = matchData(matchId);
      return isSignedIn() && (
        (('scorer1UserId' in data) && data.scorer1UserId == request.auth.uid) ||
        (('scorer2UserId' in data) && data.scorer2UserId == request.auth.uid) ||
        request.auth.uid in data.get('scorerIds', []) ||
        isOfficialScorerFromSnapshot(data)
      );
    }

    function isOfficialScorerFromSnapshot(data) {
      return ('officials' in data)
        && data.officials is map
        && (
          (('scorers' in data.officials)
            && data.officials.scorers is list
            && data.officials.scorers.size() > 0
            && officialEntryUserId(data.officials.scorers[0]) == request.auth.uid)
          || (('scorers' in data.officials)
            && data.officials.scorers is list
            && data.officials.scorers.size() > 1
            && officialEntryUserId(data.officials.scorers[1]) == request.auth.uid)
          || (('scorer1' in data.officials)
            && officialEntryUserId(data.officials.scorer1) == request.auth.uid)
          || (('scorer2' in data.officials)
            && officialEntryUserId(data.officials.scorer2) == request.auth.uid)
        );
    }

    function canWriteTargetRevision(matchId) {
      return isMatchScorer(matchId) || isAssignedMatchScorer(matchId);
    }

    function validTargetStateField(ts) {
      return ts is map
        && (!('revisionMethod' in ts)
            || ts.revisionMethod in ['DLS', 'dls', 'manual'])
        && (!('targetRevisionMethod' in ts)
            || ts.targetRevisionMethod in ['DLS', 'dls', 'manual'])
        && (!('originalOvers' in ts)
            || (ts.originalOvers is int && ts.originalOvers > 0))
        && (!('revisedOvers' in ts)
            || (ts.revisedOvers is int && ts.revisedOvers > 0))
        && (!('revisedTarget' in ts)
            || (ts.revisedTarget is int && ts.revisedTarget > 0))
        && (!('originalTarget' in ts)
            || (ts.originalTarget is int && ts.originalTarget > 0))
        && (!('dlsApplied' in ts) || ts.dlsApplied is bool)
        && (!('pendingChaseTarget' in ts)
            || (ts.pendingChaseTarget is int && ts.pendingChaseTarget > 0))
        && (!('revisedTotalOvers' in ts)
            || (ts.revisedTotalOvers is int && ts.revisedTotalOvers > 0))
        && (!('considerAllOversForNrr' in ts) || ts.considerAllOversForNrr is bool)
        && (!('matchOutcome' in ts) || ts.matchOutcome in ['draw', 'abandoned'])
        && (!('abandonedReason' in ts) || ts.abandonedReason is string)
        && (!('liveBannerMessage' in ts) || ts.liveBannerMessage is string)
        && (!('liveBannerDismissed' in ts) || ts.liveBannerDismissed is bool);
    }

    function validMatchRevisionCreate() {
      let d = request.resource.data;
      return d.type is string
        && d.type.size() > 0
        && d.type in ['DLS', 'dls', 'manual', 'penalty_added', 'penalty_removed']
        && d.createdAt is string
        && (!('revisionMethod' in d)
            || d.revisionMethod in ['DLS', 'dls', 'manual'])
        && (!('originalOvers' in d) || d.originalOvers is int)
        && (!('revisedOvers' in d) || d.revisedOvers is int)
        && (!('oversLost' in d) || d.oversLost is int)
        && (!('oldTarget' in d) || d.oldTarget is int)
        && (!('newTarget' in d) || d.newTarget is int)
        && (!('reason' in d) || d.reason is string)
        && (!('penaltyRuns' in d) || d.penaltyRuns is int)
        && (!('createdBy' in d) || d.createdBy is string);
    }

    function validMatchTimelineCreate() {
      let d = request.resource.data;
      return d.title is string
        && d.title.size() > 0
        && d.createdAt is string
        && (!('subtitle' in d) || d.subtitle is string)
        && (!('createdBy' in d) || d.createdBy is string);
    }

    function validTargetRevisionMatchUpdate() {
      let data = request.resource.data;
      return validMatchUpdate()
        && (!('targetState' in data) || validTargetStateField(data.targetState));
    }

    function isTargetRevisionRelatedUpdate() {
      let diff = request.resource.data.diff(resource.data);
      return diff.affectedKeys().hasAny([
        'targetState',
        'innings',
        'status',
        'winnerTeamId',
        'resultSummary',
        'completedAt',
        'rules',
        'activeMatchBreak',
        'matchBreakHistory',
        'teamAPlayingPlayers',
        'teamASubstitutePlayers',
        'teamBPlayingPlayers',
        'teamBSubstitutePlayers',
        'teamASquadIds',
        'teamBSquadIds',
        'startedAt',
        'currentScorerId',
        'scorerIds',
      ]);
    }

    function canUpdateMatchForTargetRevision(matchId) {
      return isMatchScorer(matchId)
        || isMatchCreator(matchId)
        || isValidScorerTakeover()
        || (isAssignedMatchScorer(matchId) && isTargetRevisionRelatedUpdate());
    }

    function isStreamMetadataUpdate() {
      let diff = request.resource.data.diff(resource.data);
      return diff.affectedKeys().hasOnly(['stream'])
        || diff.affectedKeys().hasOnly(['stream', 'updatedAt']);
    }

    /// Any signed-in CrickFlow user may update stream metadata (go live).
    function canUpdateStreamMetadata(matchId) {
      return isSignedIn();
    }

    function isValidScorerTakeover() {
      let old = resource.data;
      let neu = request.resource.data;
      return isSignedIn()
        && neu.currentScorerId == request.auth.uid
        && ('scorerOwnershipToken' in old)
        && old.scorerOwnershipToken == neu.scorerOwnershipToken
        && (!('currentScorerId' in old) || old.currentScorerId != neu.currentScorerId);
    }

    // --- Match document validation (start-match + scoring fields) ---

    function validCricketMatchType(t) {
      // App supports limitedOvers | indoor | testMatch; legacy values kept for old docs.
      return t in [
        'limitedOvers',
        'indoor',
        'testMatch',
        'boxTurf',
        'pairCricket',
        'theHundred',
      ];
    }

    function validPitchType(t) {
      return t in ['rough', 'cement', 'turf', 'astroturf', 'matting'];
    }

    function validBallType(t) {
      return t in ['tennis', 'leather', 'indoor'];
    }

    function validMatchOfficialRole(r) {
      return r in ['umpires', 'scorers', 'liveStreamer', 'others'];
    }

    function validPowerplaySlot(slot) {
      return slot is list && slot.size() <= 50;
    }

    function validMatchRules(rules) {
      return rules is map
        && rules.keys().hasOnly([
          'format',
          'cricketMatchType',
          'ballType',
          'totalOvers',
          'ballsPerOver',
          'playersPerTeam',
          'oversPerBowler',
          'isManualOversPerBowler',
          'wideRuns',
          'noBallRuns',
          'freeHitEnabled',
          'maxInnings',
          'maxWickets',
          'superOverEnabled',
          'powerplayOvers',
          'powerplaySlot1',
          'powerplaySlot2',
          'powerplaySlot3',
          'powerplayLabels',
          'wagonWheelEnabled',
          'wagonWheelDots',
          'wagonWheelRuns123',
          'wagonWheelShotSelection',
          'wideCountsAsLegalDelivery',
          'noBallCountsAsLegalDelivery',
          'impactPlayerEnabled',
          'pitchType',
          'matchOfficials',
          'pointsPerWin',
          'pointsPerTie',
          'pointsPerLoss',
          'extrasCountToBowler',
          'lastManStanding',
          'notes',
        ])
        && (!('cricketMatchType' in rules) || validCricketMatchType(rules.cricketMatchType))
        && (!('ballType' in rules) || validBallType(rules.ballType))
        && (!('pitchType' in rules) || validPitchType(rules.pitchType))
        && (!('matchOfficials' in rules)
            || (rules.matchOfficials is list
                && rules.matchOfficials.size() <= 8))
        && (!('powerplaySlot1' in rules) || validPowerplaySlot(rules.powerplaySlot1))
        && (!('powerplaySlot2' in rules) || validPowerplaySlot(rules.powerplaySlot2))
        && (!('powerplaySlot3' in rules) || validPowerplaySlot(rules.powerplaySlot3))
        && (!('powerplayLabels' in rules)
            || (rules.powerplayLabels is list && rules.powerplayLabels.size() <= 10))
        && (!('totalOvers' in rules) || (rules.totalOvers is int && rules.totalOvers > 0 && rules.totalOvers <= 200))
        && (!('ballsPerOver' in rules) || (rules.ballsPerOver is int && rules.ballsPerOver >= 1 && rules.ballsPerOver <= 12))
        && (!('playersPerTeam' in rules) || (rules.playersPerTeam is int && rules.playersPerTeam >= 1 && rules.playersPerTeam <= 25))
        && (!('oversPerBowler' in rules) || (rules.oversPerBowler is int && rules.oversPerBowler >= 1 && rules.oversPerBowler <= 50))
        && (!('isManualOversPerBowler' in rules) || rules.isManualOversPerBowler is bool)
        && (!('totalOvers' in rules) || !('oversPerBowler' in rules)
            || rules.oversPerBowler <= rules.totalOvers)
        && (!('wideRuns' in rules) || (rules.wideRuns is int && rules.wideRuns >= 0 && rules.wideRuns <= 10))
        && (!('noBallRuns' in rules) || (rules.noBallRuns is int && rules.noBallRuns >= 0 && rules.noBallRuns <= 10));
    }

    function validMatchPlayerSnapshotList(list) {
      return list is list && list.size() <= 50;
    }

    function validMatchSetupFields(data) {
      return (!('teamAPlayingPlayers' in data)
              || validMatchPlayerSnapshotList(data.teamAPlayingPlayers))
        && (!('teamASubstitutePlayers' in data)
              || validMatchPlayerSnapshotList(data.teamASubstitutePlayers))
        && (!('teamBPlayingPlayers' in data)
              || validMatchPlayerSnapshotList(data.teamBPlayingPlayers))
        && (!('teamBSubstitutePlayers' in data)
              || validMatchPlayerSnapshotList(data.teamBSubstitutePlayers))
        && (!('teamASquadIds' in data)
              || (data.teamASquadIds is list && data.teamASquadIds.size() <= 50))
        && (!('teamBSquadIds' in data)
              || (data.teamBSquadIds is list && data.teamBSquadIds.size() <= 50))
        && (!('officials' in data) || data.officials is map);
    }

    function playingSquadWithinLimit(data) {
      let rules = data.rules;
      let limit = ('playersPerTeam' in rules && rules.playersPerTeam is int)
        ? rules.playersPerTeam
        : 11;
      return (!('teamAPlayingPlayers' in data)
              || data.teamAPlayingPlayers.size() <= limit)
        && (!('teamBPlayingPlayers' in data)
              || data.teamBPlayingPlayers.size() <= limit)
        && (!('teamASquadIds' in data) || data.teamASquadIds.size() <= limit)
        && (!('teamBSquadIds' in data) || data.teamBSquadIds.size() <= limit);
    }

    function isPlatformAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/app_meta/platform_admins)
        && request.auth.uid in get(
          /databases/$(database)/documents/app_meta/platform_admins
        ).data.get('uids', []);
    }

    function validMatchCreate() {
      let data = request.resource.data;
      return data.keys().hasAll(['title', 'teamAName', 'teamBName', 'rules', 'createdBy'])
        && data.createdBy == request.auth.uid
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 200
        && data.teamAName is string
        && data.teamBName is string
        && validMatchRules(data.rules)
        && validMatchSetupFields(data)
        && playingSquadWithinLimit(data)
        && (!('mediaByCode' in data) || data.mediaByCode is map);
    }

    function validMatchBreakField(br) {
      return br is map
        && br.breakType is string
        && br.startTime is string
        && br.startedBy is string
        && br.status is string
        && (!('reason' in br) || br.reason is string);
    }

    function validMatchBreakHistoryEntry(entry) {
      return entry is map
        && entry.breakType is string
        && entry.startTime is string
        && entry.durationSeconds is int
        && (!('endTime' in entry) || entry.endTime is string)
        && (!('reason' in entry) || entry.reason is string);
    }

    function validMatchUpdate() {
      let data = request.resource.data;
      return (!('rules' in data) || validMatchRules(data.rules))
        && validMatchSetupFields(data)
        && playingSquadWithinLimit(data)
        && (!('mediaByCode' in data) || data.mediaByCode is map)
        && (!('activeMatchBreak' in data) || validMatchBreakField(data.activeMatchBreak))
        && (!('matchBreakHistory' in data)
            || (data.matchBreakHistory is list
                && data.matchBreakHistory.size() <= 50));
    }

    function isWalkInPlayer() {
      return !('userId' in resource.data)
        || resource.data.userId == null
        || resource.data.userId == '';
    }

    function ownsPlayerProfile(playerDocId) {
      return playerDocId == request.auth.uid
        || (('userId' in resource.data) && resource.data.userId == request.auth.uid);
    }

    function isTeamOwner(teamId) {
      return isSignedIn()
        && teamDoc(teamId).get('createdBy', '') == request.auth.uid;
    }

    function teamDoc(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId)).data;
    }

    function authOwnsPlayerDoc(playerDocId) {
      return playerDocId == request.auth.uid
        || (
          exists(/databases/$(database)/documents/players/$(playerDocId))
          && get(/databases/$(database)/documents/players/$(playerDocId)).data.get('userId', '') == request.auth.uid
        );
    }

    function isTeamCaptain(teamId) {
      let capId = teamDoc(teamId).get('captainId', '');
      return isSignedIn()
        && capId is string
        && capId.size() > 0
        && authOwnsPlayerDoc(capId);
    }

    function isTeamViceCaptain(teamId) {
      let vcId = teamDoc(teamId).get('viceCaptainId', '');
      return isSignedIn()
        && vcId is string
        && vcId.size() > 0
        && authOwnsPlayerDoc(vcId);
    }

    function canManageTeamRequests(teamId) {
      return isTeamOwner(teamId) || isTeamCaptain(teamId) || isTeamViceCaptain(teamId);
    }

    function rosterChangeTeamId() {
      return request.resource.data.get('rosterChangeTeamId', '');
    }

    function isTeamLeadershipAssigningPlayer() {
      let neu = request.resource.data;
      let changeId = rosterChangeTeamId();
      let teamId = changeId != '' ? changeId : neu.get('teamId', '');
      return isSignedIn()
        && teamId is string
        && teamId.size() > 0
        && canManageTeamRequests(teamId)
        && teamId in neu.get('teamIds', []);
    }

    function isLeadershipRosterUpdate(teamId) {
      let old = resource.data;
      let neu = request.resource.data;
      return canManageTeamRequests(teamId)
        && teamPublicCodeImmutable()
        && old.get('createdBy', '') == neu.get('createdBy', '');
    }

    function isLeadershipRemovingPlayer() {
      let old = resource.data;
      let neu = request.resource.data;
      let changeId = rosterChangeTeamId();
      let teamId = changeId != '' ? changeId : old.get('teamId', '');
      let team = teamDoc(teamId);
      let targetId = playerId;
      let targetIsOwner = targetId == team.get('createdBy', '')
        || old.get('userId', '') == team.get('createdBy', '');
      let targetIsCaptain = team.get('captainId', '') == targetId;
      let targetIsVc = team.get('viceCaptainId', '') == targetId;
      return isSignedIn()
        && teamId is string
        && teamId.size() > 0
        && (
          (teamId in old.get('teamIds', []) && !(teamId in neu.get('teamIds', [])))
          || (old.get('teamId', '') == teamId
            && (neu.get('teamId', '') == '' || neu.teamId == null))
        )
        && !targetIsOwner
        && (
          isTeamOwner(teamId)
          || (isTeamCaptain(teamId) && !targetIsCaptain && !targetIsVc)
          || (isTeamViceCaptain(teamId) && !targetIsCaptain)
        );
    }

    function isTeamOwnerRemovingPlayer() {
      let old = resource.data;
      let neu = request.resource.data;
      let changeId = rosterChangeTeamId();
      let teamId = changeId != '' ? changeId : old.get('teamId', '');
      return teamId is string
        && teamId.size() > 0
        && isTeamOwner(teamId)
        && (
          (teamId in old.get('teamIds', []) && !(teamId in neu.get('teamIds', [])))
          || (old.get('teamId', '') == teamId
            && (neu.get('teamId', '') == '' || neu.teamId == null))
        );
    }

    function isTeamOwnerAssigningPlayer() {
      let neu = request.resource.data;
      let changeId = rosterChangeTeamId();
      let teamId = changeId != '' ? changeId : neu.get('teamId', '');
      return isSignedIn()
        && teamId is string
        && teamId.size() > 0
        && isTeamOwner(teamId)
        && teamId in neu.get('teamIds', []);
    }

    function userPublicPlayerIdImmutable() {
      return !('playerId' in resource.data)
        || resource.data.playerId == null
        || resource.data.playerId == ''
        || !('playerId' in request.resource.data)
        || request.resource.data.playerId == resource.data.playerId;
    }

    function validPlayerFollowCreate(followId) {
      let d = request.resource.data;
      return d.keys().hasAll(['followerUserId', 'followedUserId', 'createdAt'])
        && d.followerUserId == request.auth.uid
        && d.followedUserId is string
        && d.followedUserId.size() > 0
        && d.followedUserId != request.auth.uid
        && followId == d.followerUserId + '_' + d.followedUserId;
    }

    function canDeletePlayerFollow() {
      return isSignedIn()
        && resource.data.followerUserId == request.auth.uid;
    }

    function playerPublicIdImmutable() {
      return !('playerId' in resource.data)
        || resource.data.playerId == null
        || resource.data.playerId == ''
        || !('playerId' in request.resource.data)
        || request.resource.data.playerId == resource.data.playerId;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && userPublicPlayerIdImmutable();
      allow delete: if isOwner(userId);

      match /teamNotificationPrefs/{teamId} {
        allow read, write: if isOwner(userId);
      }

      match /profileViews/{viewerId} {
        allow read: if isOwner(userId);
        allow create, update: if isSignedIn()
          && request.auth.uid == viewerId
          && userId != request.auth.uid
          && request.resource.data.keys().hasOnly(['lastViewedAt']);
        allow delete: if false;
      }

      match /social/{docId} {
        // Realtime counters — mirrored by Cloud Functions (admin SDK).
        allow read: if true;
        allow create, update, delete: if false;
      }
    }

    function teamPublicCodeImmutable() {
      return !('teamCode' in resource.data)
        || resource.data.teamCode == null
        || resource.data.teamCode == ''
        || !('teamCode' in request.resource.data)
        || request.resource.data.teamCode == resource.data.teamCode;
    }

    /// Member removes themselves from roster.
    function isMemberSelfLeaveTeamUpdate(teamId) {
      let old = resource.data;
      let neu = request.resource.data;
      let uid = request.auth.uid;
      let playerSnap = get(/databases/$(database)/documents/players/$(uid));
      let hadTeamId = playerSnap.exists
        && (
          playerSnap.data.get('teamId', '') == teamId
          || teamId in playerSnap.data.get('teamIds', [])
        );
      let wasOnRoster = uid in old.playerIds;
      return isSignedIn()
        && (hadTeamId || wasOnRoster)
        && old.createdBy == neu.createdBy
        && teamPublicCodeImmutable()
        && (!wasOnRoster || !(uid in neu.playerIds))
        && neu.diff(old).affectedKeys().hasOnly([
          'playerIds',
          'memberCount',
          'updatedAt',
          'captainId',
          'viceCaptainId',
        ]);
    }

    /// Owner leaves and transfers createdBy to another member.
    function isOwnerLeaveTeamUpdate() {
      let old = resource.data;
      let neu = request.resource.data;
      let uid = request.auth.uid;
      return isSignedIn()
        && old.createdBy == uid
        && neu.createdBy is string
        && neu.createdBy != uid
        && neu.createdBy.size() > 0
        && teamPublicCodeImmutable()
        && neu.diff(old).affectedKeys().hasOnly([
          'playerIds',
          'memberCount',
          'updatedAt',
          'captainId',
          'viceCaptainId',
          'createdBy',
        ]);
    }

    /// Player removes themselves from one team roster.
    function isMemberSelfLeavePlayerUpdate() {
      let old = resource.data;
      let neu = request.resource.data;
      let teamId = rosterChangeTeamId();
      let oldTeams = old.get('teamIds', []);
      let newTeams = neu.get('teamIds', []);
      let multiTeamLeave = ownsPlayerProfile(playerId)
        && teamId != ''
        && teamId in oldTeams
        && !(teamId in newTeams);
      let legacyLeave = ownsPlayerProfile(playerId)
        && teamId == ''
        && ('teamId' in old)
        && old.get('teamId', '') != ''
        && (
          !('teamId' in neu)
          || neu.get('teamId', '') == ''
          || neu.teamId == null
        );
      return multiTeamLeave || legacyLeave;
    }

    function isUserJoinRequestWrite(requestId) {
      return isSignedIn()
        && requestId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.get('requestType', 'join_request') == 'join_request'
        && request.resource.data.status == 'pending'
        && request.resource.data.playerId is string
        && request.resource.data.playerName is string;
    }

    function isTeamLeadershipInvitationWrite(teamId, requestId) {
      return isSignedIn()
        && canManageTeamRequests(teamId)
        && request.resource.data.get('requestType', '') == 'invitation'
        && request.resource.data.status == 'pending'
        && request.resource.data.userId == requestId
        && request.resource.data.invitedByUserId == request.auth.uid
        && request.resource.data.playerId is string
        && request.resource.data.playerName is string;
    }

    function isInviteeRespondingToInvitation() {
      return isSignedIn()
        && requestId == request.auth.uid
        && resource.data.get('requestType', '') == 'invitation'
        && resource.data.status == 'pending'
        && resource.data.userId == request.auth.uid
        && request.resource.data.status in ['accepted', 'rejected']
        && request.resource.data.resolvedBy == request.auth.uid;
    }

    function isTeamOwnerFullUpdate() {
      return isSignedIn()
        && resource.data.get('createdBy', '') == request.auth.uid
        && request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '')
        && teamPublicCodeImmutable();
    }

    match /app_meta/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && (docId == 'cf_player_ids' || docId == 'cf_team_ids');
      allow delete: if false;
    }

    match /team_roster_reports/{reportId} {
      allow read: if isSignedIn() && (
        resource.data.reporterUserId == request.auth.uid || isPlatformAdmin()
      );
      allow create: if isSignedIn()
        && request.resource.data.reporterUserId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.teamId is string
        && request.resource.data.teamId.size() > 0
        && request.resource.data.teamName is string
        && request.resource.data.playerId is string
        && request.resource.data.playerId.size() > 0;
      allow update: if isPlatformAdmin()
        && request.resource.data.reporterUserId == resource.data.reporterUserId
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.playerId == resource.data.playerId
        && request.resource.data.status in ['pending', 'reviewing', 'resolved', 'dismissed'];
      allow delete: if false;
    }

    /// Home carousel: admin ads + announcements. Public read; admin write.
    match /home_promotions/{promoId} {
      allow read: if true;
      allow create, update, delete: if isPlatformAdmin();
    }

    match /teams/{teamId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isTeamOwnerFullUpdate()
        || isMemberSelfLeaveTeamUpdate(teamId)
        || isOwnerLeaveTeamUpdate()
        || isLeadershipRosterUpdate(teamId);
      allow delete: if isSignedIn()
        && resource.data.createdBy == request.auth.uid
        && teamPublicCodeImmutable();

      match /join_requests/{requestId} {
        allow read: if isSignedIn() && (
          canManageTeamRequests(teamId) || requestId == request.auth.uid
        );
        allow create: if isUserJoinRequestWrite(requestId)
          || isTeamLeadershipInvitationWrite(teamId, requestId);
        allow update: if isUserJoinRequestWrite(requestId)
          || (
            canManageTeamRequests(teamId)
            && resource.data.status == 'pending'
            && resource.data.get('requestType', 'join_request') == 'join_request'
            && request.resource.data.status in ['accepted', 'rejected']
          )
          || isInviteeRespondingToInvitation()
          || (
            requestId == request.auth.uid
            && resource.data.status == 'pending'
            && request.resource.data.status == 'cancelled'
          );
        allow delete: if isSignedIn() && (
          requestId == request.auth.uid || canManageTeamRequests(teamId)
        );
      }
    }

    match /players/{playerId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && playerPublicIdImmutable()
        && (
          isMemberSelfLeavePlayerUpdate()
          || ownsPlayerProfile(playerId)
          || isWalkInPlayer()
          || isTeamOwnerRemovingPlayer()
          || isTeamOwnerAssigningPlayer()
          || isTeamLeadershipAssigningPlayer()
          || isLeadershipRemovingPlayer()
        );
      allow delete: if isSignedIn() && (
        playerId == request.auth.uid ||
        resource.data.userId == request.auth.uid
      );
    }

    match /matches/{matchId} {
      allow read: if true;
      allow create: if isSignedIn() && validMatchCreate();
      allow update: if (canUpdateMatchForTargetRevision(matchId)
        && validTargetRevisionMatchUpdate())
        || (canUpdateStreamMetadata(matchId) && isStreamMetadataUpdate());
      allow delete: if canDeleteMatch(matchId);

      match /ball_events/{eventId} {
        allow read: if true;
        allow create: if isMatchScorer(matchId);
        allow delete: if isMatchScorer(matchId);
        allow update: if false;
      }

      match /overlay/{docId} {
        allow read: if true;
        allow write: if isMatchScorer(matchId);
      }

      match /replayMarkers/{markerId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }

      match /streamSessions/{sessionId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();

        match /replayMarkers/{markerId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow update, delete: if false;
        }
      }

      match /highlights/{highlightId} {
        allow read: if true;
        allow write: if false;
      }

      match /activity_logs/{logId} {
        allow read: if isSignedIn();
        allow create: if isMatchScorer(matchId) || isValidScorerTakeover();
        allow update, delete: if false;
      }

      match /matchRevisions/{revisionId} {
        allow read: if true;
        allow create: if canWriteTargetRevision(matchId) && validMatchRevisionCreate();
        allow update, delete: if false;
      }

      match /matchTimeline/{eventId} {
        allow read: if true;
        allow create: if canWriteTargetRevision(matchId) && validMatchTimelineCreate();
        allow update, delete: if false;
      }

      match /public/{docId} {
        allow read: if true;
        allow create, update: if isMatchScorer(matchId);
        allow delete: if false;
      }

      match /engagement/{docId} {
        allow read: if true;
        // Public view counter — only the stats doc may be written.
        allow create, update: if docId == 'stats';
        allow delete: if false;
      }

      match /liveAudience/{userId} {
        allow read: if true;
        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.keys().hasOnly(['lastSeen']);
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /webrtc/{docId} {
        allow read: if isSignedIn();
        allow create, update: if isMatchScorer(matchId) || isSignedIn();
        allow delete: if isMatchCreator(matchId);

        match /candidates/{candidateId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow update, delete: if false;
        }
      }
    }

    match /tournaments/{tournamentId} {
      allow read: if true;
      allow create: if isTournamentOrganizerOnCreate();
      allow update: if isTournamentOrganizer(tournamentId)
        || isTeamLeadershipAcceptingInvitation(tournamentId);
      allow delete: if isTournamentOrganizer(tournamentId);
    }

    match /tournament_groups/{groupId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.tournamentId is string
        && isTournamentOrganizer(request.resource.data.tournamentId);
      allow update, delete: if isSignedIn()
        && resource.data.tournamentId is string
        && isTournamentOrganizer(resource.data.tournamentId);
    }

    match /tournament_rounds/{roundId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.tournamentId is string
        && isTournamentOrganizer(request.resource.data.tournamentId);
      allow update, delete: if isSignedIn()
        && resource.data.tournamentId is string
        && isTournamentOrganizer(resource.data.tournamentId);
    }

    match /tournament_points_tables/{tableId} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.resource.data.tournamentId is string
        && isTournamentOrganizer(request.resource.data.tournamentId);
      allow delete: if isSignedIn()
        && resource.data.tournamentId is string
        && isTournamentOrganizer(resource.data.tournamentId);
    }

    match /tournament_officials/{officialId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.tournamentId is string
        && isTournamentOrganizer(request.resource.data.tournamentId);
      allow update: if isSignedIn()
        && resource.data.tournamentId is string
        && (
          isTournamentOrganizer(resource.data.tournamentId)
          || canOfficialInviteeRespond()
        );
      allow delete: if isSignedIn()
        && resource.data.tournamentId is string
        && isTournamentOrganizer(resource.data.tournamentId);
    }

    match /tournament_sponsors/{sponsorId} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.resource.data.tournamentId is string
        && isTournamentOrganizer(request.resource.data.tournamentId);
      allow delete: if isSignedIn()
        && resource.data.tournamentId is string
        && isTournamentOrganizer(resource.data.tournamentId);
    }

    match /tournament_analytics/{tournamentId} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && exists(/databases/$(database)/documents/tournaments/$(tournamentId));
      allow delete: if isTournamentOrganizer(tournamentId);
    }

    match /tournament_rules/{tournamentId} {
      allow read: if true;
      allow create, update, delete: if isTournamentOrganizer(tournamentId);
    }

    match /tournament_members/{memberId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.tournamentId is string
        && isTournamentOrganizer(request.resource.data.tournamentId);
      allow update, delete: if isSignedIn()
        && (
          resource.data.userId == request.auth.uid
          || isTournamentOrganizer(resource.data.tournamentId)
        );
    }

    function canManageTournamentTeams(tournamentId) {
      return isTournamentOrganizer(tournamentId);
    }

    function tournamentTeamRequestDocId(tournamentId, teamId) {
      return tournamentId + '_' + teamId;
    }

    function tournamentTeamRequestPath(tournamentId, teamId) {
      return /databases/$(database)/documents/tournament_team_requests/$(tournamentTeamRequestDocId(tournamentId, teamId));
    }

    function hasApprovedInvitationByUser(tournamentId, teamId) {
      let path = tournamentTeamRequestPath(tournamentId, teamId);
      return exists(path)
        && get(path).data.status == 'approved'
        && get(path).data.requestType == 'invitation'
        && get(path).data.approvedByUserId == request.auth.uid;
    }

    /// Team owner/captain/VC accepting an organiser invitation may add their team
    /// to the tournament roster (request must already be marked approved).
    function isTeamLeadershipAcceptingInvitation(tournamentId) {
      let marker = request.resource.data.get('leadershipRosterTeamId', '');
      let oldIds = resource.data.get('teamIds', []);
      let newIds = request.resource.data.get('teamIds', []);
      return marker is string
        && marker.size() > 0
        && canManageTeamRequests(marker)
        && !(marker in oldIds)
        && marker in newIds
        && newIds.size() == oldIds.size() + 1
        && newIds.hasAll(oldIds)
        && hasApprovedInvitationByUser(tournamentId, marker)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['teamIds', 'pointsTable', 'leadershipRosterTeamId', 'updatedAt']);
    }

    function validTournamentTeamRequestCreate() {
      let data = request.resource.data;
      return data.tournamentId is string
        && data.tournamentId.size() > 0
        && data.teamId is string
        && data.teamId.size() > 0
        && data.requestType in ['invitation', 'join_request']
        && data.status == 'pending'
        && data.requestedByUserId is string
        && data.requestedByUserId == request.auth.uid;
    }

    function validTournamentTeamRequestStatusTransition() {
      let next = request.resource.data.status;
      return next in ['approved', 'rejected', 'withdrawn'];
    }

    function validTournamentTeamRequestDirectAdd() {
      let data = request.resource.data;
      return data.tournamentId is string
        && data.teamId is string
        && data.requestType == 'invitation'
        && data.status == 'approved'
        && data.requestedByUserId == request.auth.uid
        && canManageTournamentTeams(data.tournamentId);
    }

    match /tournament_team_requests/{requestId} {
      allow read: if true;

      allow create: if isSignedIn()
        && (
          (
            validTournamentTeamRequestCreate()
            && (
              (
                request.resource.data.requestType == 'invitation'
                && canManageTournamentTeams(request.resource.data.tournamentId)
              )
              || (
                request.resource.data.requestType == 'join_request'
                && canManageTeamRequests(request.resource.data.teamId)
              )
            )
          )
          || validTournamentTeamRequestDirectAdd()
        );

      allow update: if isSignedIn()
        && canManageTournamentTeams(resource.data.tournamentId)
        && request.resource.data.status == 'approved'
        && request.resource.data.requestType == 'invitation'
        && request.resource.data.requestedByUserId == request.auth.uid;

      allow update: if isSignedIn()
        && resource.data.status == 'pending'
        && validTournamentTeamRequestStatusTransition()
        && (
          (
            resource.data.requestType == 'invitation'
            && canManageTeamRequests(resource.data.teamId)
            && request.resource.data.status in ['approved', 'rejected']
          )
          || (
            resource.data.requestType == 'join_request'
            && canManageTournamentTeams(resource.data.tournamentId)
            && request.resource.data.status in ['approved', 'rejected']
          )
          || (
            resource.data.requestType == 'join_request'
            && canManageTeamRequests(resource.data.teamId)
            && request.resource.data.status == 'withdrawn'
          )
        );

      allow update: if isSignedIn()
        && canManageTournamentTeams(resource.data.tournamentId)
        && resource.data.status in ['approved', 'rejected']
        && request.resource.data.status == 'withdrawn'
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt']);

      allow update: if isSignedIn()
        && validTournamentTeamRequestCreate()
        && resource.data.status in ['rejected', 'withdrawn']
        && request.resource.data.status == 'pending'
        && (
          (
            request.resource.data.requestType == 'invitation'
            && canManageTournamentTeams(resource.data.tournamentId)
          )
          || (
            request.resource.data.requestType == 'join_request'
            && canManageTeamRequests(resource.data.teamId)
          )
        );

      allow delete: if isSignedIn()
        && canManageTournamentTeams(resource.data.tournamentId);
    }

    match /badges/{badgeId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /streaming_credentials/{userId} {
      // OAuth refresh tokens — written only by Cloud Functions (Admin SDK).
      allow read, write: if false;
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId is string
        && request.resource.data.userId.size() > 0
        && request.resource.data.title is string
        && request.resource.data.body is string;
    }

    match /matchFollowers/{followerId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.matchId is string
        && request.resource.data.matchId.size() > 0;
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /playerFollows/{followId} {
      allow read: if isSignedIn();
      allow create: if validPlayerFollowCreate(followId);
      allow delete: if canDeletePlayerFollow();
      allow update: if false;
    }

    match /scoringIssueReports/{reportId} {
      allow read: if isSignedIn()
        && (resource.data.reportedBy == request.auth.uid
            || isMatchScorer(resource.data.matchId));
      allow create: if isSignedIn()
        && request.resource.data.reportedBy == request.auth.uid
        && request.resource.data.matchId is string
        && request.resource.data.matchId.size() > 0
        && request.resource.data.issueType is string
        && request.resource.data.createdAt is string;
      allow update, delete: if false;
    }

    match /community_posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.authorId == request.auth.uid;
    }

    match /fantasy_leagues/{leagueId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.createdBy == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.createdBy == request.auth.uid;

      match /entries/{entryId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid;
        allow update: if isSignedIn()
          && resource.data.userId == request.auth.uid;
        allow delete: if isSignedIn()
          && resource.data.userId == request.auth.uid;
      }
    }
  }
}
