rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function matchData(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data;
    }

    function isMatchCreator(matchId) {
      return isSignedIn() && matchData(matchId).createdBy == request.auth.uid;
    }

    function isMatchScorer(matchId) {
      return isSignedIn() && (
        isMatchCreator(matchId) ||
        request.auth.uid in matchData(matchId).scorerIds
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId);
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn()
        && resource.data.createdBy == request.auth.uid;
    }

    match /players/{playerId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn() && (
        playerId == request.auth.uid ||
        resource.data.userId == request.auth.uid
      );
    }

    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isMatchScorer(matchId) || isMatchCreator(matchId);
      allow delete: if isMatchCreator(matchId);

      match /ball_events/{eventId} {
        allow read: if isSignedIn();
        allow create: if isMatchScorer(matchId);
        allow delete: if isMatchScorer(matchId);
        allow update: if false;
      }

      match /overlay/{docId} {
        allow read: if true;
        allow write: if isMatchScorer(matchId);
      }
    }

    match /tournaments/{tournamentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.createdBy == request.auth.uid;
    }

    match /badges/{badgeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
    }
  }
}
