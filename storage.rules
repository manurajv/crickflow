rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /teams/{teamId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /players/{playerId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
